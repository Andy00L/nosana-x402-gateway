# Solana network for payments and Nosana API: devnet | mainnet
NOSANA_X402_NETWORK=devnet

# Treasury wallet (base58 pubkey) that receives USDC payments. Required.
TREASURY_WALLET_ADDRESS=

# x402 facilitator base URL. PayAI is gasless and needs no API key on devnet.
FACILITATOR_URL=https://facilitator.payai.network

# Nosana API key for credits-backed provisioning. Optional: without it the
# gateway serves quotes but refuses every payment before settlement.
NOSANA_API_KEY=

# Secret for signing rent session JWTs. Required, at least 32 characters.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Base58 secret key of the treasury wallet. Not read by the gateway yet;
# reserved for the refund path. Keep it out of code and logs.
TREASURY_WALLET_SECRET=

# SQLite file recording payment settlements (anti-replay and refund ledger).
SETTLEMENT_DB_PATH=data/gateway.db

# Token guarding GET /admin/ledger (reconciliation). Optional: when unset the
# admin route returns 404 and exposes nothing. Set to a long random string.
ADMIN_TOKEN=

# Credits float floor in USD cents. The gateway refuses a rental that would
# drop its Nosana credits balance below this. Default 0.
MIN_CREDITS_FLOOR_CENTS=0

# HTTP port the gateway listens on.
PORT=3000
