# dependencies
node_modules/

# secrets (never staged)
.env
.env.*
!.env.example

# build output
dist/

# local state (settlement database)
data/

# scratch files (per SKILL_GENERAL.md)
.scratch/

# agent tooling and standards kit: travels with the project on disk, kept out
